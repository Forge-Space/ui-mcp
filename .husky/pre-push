#!/usr/bin/env bash
set -euo pipefail

echo "Running pre-push validations..."

FAILED=0

# 1. Lint check
echo "  lint..."
if ! npm run lint; then
  echo "  FAIL: lint"
  FAILED=1
fi

# 2. Format check
echo "  format..."
if ! npm run format:check; then
  echo "  FAIL: format"
  FAILED=1
fi

# 3. Type check
echo "  tsc --noEmit..."
if ! npx tsc --noEmit; then
  echo "  FAIL: type check"
  FAILED=1
fi

# 4. Tests
echo "  tests..."
if ! npm test; then
  echo "  FAIL: tests"
  FAILED=1
fi

# 5. Build
echo "  build..."
if ! npm run build; then
  echo "  FAIL: build"
  FAILED=1
fi

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
if [ $FAILED -eq 0 ]; then
  echo "All pre-push validations passed."
  echo "Safe to push to remote."
else
  echo "Some validations failed. Fix the issues above."
  echo "You can skip with: git push --no-verify (not recommended)"
  exit 1
fi
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
